{
  "model": "opusplan",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "🧠 Jacking into the Net...",
      "👁️ Booting Optical Camo...",
      "🤖 Syncing with Motoko...",
      "💊 Popping Sandevistan...",
      "🔌 Flatline Detected, Reconnecting...",
      "🏙️ Diving into Nightcity...",
      "⚡ Overclocking the Cyborg Brain...",
      "📡 Intercepting Ghost Signal...",
      "🩸 電脳接続中...",
      "🌐 バベルの塔を解析中...",
      "🔫 義体をキャリブレーション中...",
      "💀 ニルヴァーシュ、起動...",
      "🕶️ Tracing the Laughing Man..."
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/icm hook pre"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read -r f; if [[ \"$f\" == *.md ]]; then root=$(git -C \"$(dirname \"$f\")\" rev-parse --show-toplevel 2>/dev/null || dirname \"$f\"); output=$(cd \"$root\" && markdownlint \"$f\" 2>&1); rc=$?; if [ $rc -ne 0 ]; then jq -n --arg f \"$f\" --arg o \"$output\" '{\"hookSpecificOutput\":{\"hookEventName\":\"PostToolUse\",\"additionalContext\":(\"markdownlint issues in \"+$f+\":\\n\"+$o)}}'; fi; fi; } 2>/dev/null || true",
            "statusMessage": "Running markdownlint..."
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read -r f; if [[ \"$f\" == *.sh ]]; then out=\"\"; if ! o=$(bash -n \"$f\" 2>&1); then out+=\"[bash -n]\\n${o}\\n\"; fi; if ! o=$(shellcheck \"$f\" 2>&1); then out+=\"[shellcheck]\\n${o}\\n\"; fi; if ! o=$(shfmt -d \"$f\" 2>&1); then out+=\"[shfmt]\\n${o}\\n\"; fi; if [[ -n \"$out\" ]]; then jq -n --arg f \"$f\" --arg o \"$out\" '{\"hookSpecificOutput\":{\"hookEventName\":\"PostToolUse\",\"additionalContext\":(\"shell script issues in \"+$f+\":\\n\"+$o)}}'; fi; fi; } 2>/dev/null || true",
            "statusMessage": "Running shellcheck + shfmt..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/icm hook post"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/icm hook compact"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/icm hook prompt"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/icm hook start"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/icm hook end"
          }
        ]
      }
    ]
  }
}